# ── Spamlyser Pro Streamlit Secrets ────────────────────────────────────────
# Copy this file to `secrets.toml` and fill in your values.
#
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# These values are accessible via ``st.secrets["key"]`` at runtime.
# ──────────────────────────────────────────────────────────────────────────

# ── API keys (optional) ────────────────────────────────────────────────────
# Used for external enrichment services (e.g. URL expansion, threat intel).
# API_KEY="sk-..."

# ── Admin contact ──────────────────────────────────────────────────────────
# Shown in error pages and feedback auto-replies.
# ADMIN_EMAIL="admin@example.com"

# ── Deployment ─────────────────────────────────────────────────────────────
# When set to "true" the app hides Streamlit's default footer / menu.
# DEPLOYMENT__PRODUCTION="false"
