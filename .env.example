# ── Spamlyser Pro Environment Configuration ───────────────────────────────
# Copy this file to `.env` and adjust the values for your deployment.
#
#   cp .env.example .env
#
# All settings are optional – the app ships with sensible defaults.
# ──────────────────────────────────────────────────────────────────────────

# ── Data directory ─────────────────────────────────────────────────────────
# Where feedback, performance snapshots, and custom rules are persisted.
# Default: <project-root>/data
# SPAMLYSER_DATA_DIR=data

# ── Model settings ─────────────────────────────────────────────────────────
# HuggingFace cache directory (models are downloaded here on first use).
# Default: ~/.cache/huggingface/transformers
# SPAMLYSER_MODEL_CACHE_DIR=/app/cache

# Model name used during startup verification.
# Default: distilbert-base-uncased
# SPAMLYSER_VERIFICATION_MODEL=distilbert-base-uncased

# ── Data files (paths are relative to SPAMLYSER_DATA_DIR when not absolute) ─
# SPAMLYSER_FEEDBACK_DB=data/feedback.db
# SPAMLYSER_FEEDBACK_JSON=data/feedback_data.json
# SPAMLYSER_CUSTOM_RULES=data/custom_rules.json
# SPAMLYSER_PERFORMANCE_DATA=data/performance_data.json

# ── Application ────────────────────────────────────────────────────────────
# SPAMLYSER_APP_TITLE=Spamlyser Pro - Ensemble Edition
# SPAMLYSER_APP_ICON=🛡️
# SPAMLYSER_MAX_SMS_LENGTH=1000

# ── Feature flags ──────────────────────────────────────────────────────────
# SPAMLYSER_ENABLE_TELEMETRY=false
